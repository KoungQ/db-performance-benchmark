{
  "uid": "mysql-postgres-overview",
  "title": "MySQL vs PostgreSQL Engine Benchmark",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 10,
  "templating": {
    "list": [
      {
        "name": "run_id",
        "type": "query",
        "label": "Run ID",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(engine_benchmark_throughput_tps, run_id)",
        "query": {
          "query": "label_values(engine_benchmark_throughput_tps, run_id)",
          "refId": "Prometheus-run_id-Variable-Query"
        },
        "refresh": 2,
        "sort": 3,
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Read",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Read Throughput",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "engine_benchmark_throughput_tps{run_id=\"$run_id\",scenario=\"room-checklist-read\"}",
          "legendFormat": "{{database}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Read Processing Time",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "engine_benchmark_latency_avg_ms{run_id=\"$run_id\",scenario=\"room-checklist-read\"}",
          "legendFormat": "{{database}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
